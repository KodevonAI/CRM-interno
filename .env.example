# ─── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info

# ─── Auth ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change-me-to-a-very-long-random-string-min-64-chars
COOKIE_SECRET=change-me-to-another-very-long-random-string-min-64-chars

# ─── Database ─────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://postgres:change-me-strong-password@localhost:5432/kodevoncrm

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Ollama ───────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ─── EspoCRM (internal Docker network) ───────────────────────
ESPOCRM_URL=http://espocrm:80
ESPOCRM_API_KEY=

# ─── Encryption (for channel credentials at rest) ────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change-me-64-char-hex-string-for-aes256

# ─── Production only ──────────────────────────────────────────
DOMAIN=crm.kodevon.com

# ─── WhatsApp Cloud API (Phase 4) ────────────────────────────
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_WABA_ID=
WA_WEBHOOK_VERIFY_TOKEN=

# ─── Meta (Instagram + Facebook — Phase 4) ───────────────────
META_APP_ID=
META_APP_SECRET=
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
META_IG_ACCOUNT_ID=

# ─── Gmail (Phase 4) ─────────────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_EMAIL=
