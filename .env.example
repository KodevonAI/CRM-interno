# ─── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info

# ─── Auth ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change-me-to-a-very-long-random-string-min-64-chars
COOKIE_SECRET=change-me-to-another-very-long-random-string-min-64-chars

# ─── Database ─────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://postgres:change-me-strong-password@localhost:5432/kodevoncrm

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Ollama ───────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b   # cambiar aquí para usar otro modelo (ej: llama3.2:1b, mistral:7b)
OLLAMA_MEM_LIMIT=3g        # RAM asignada al contenedor Ollama (ajustar si cambias modelo)

# ─── EspoCRM (internal Docker network) ───────────────────────
ESPOCRM_URL=https://kodevon-interno-espo-crm-dev-espocrm.ql1yps.easypanel.host/
ESPOCRM_API_KEY=

# ─── Encryption (for channel credentials at rest) ────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change-me-64-char-hex-string-for-aes256

# ─── Production only ──────────────────────────────────────────
DOMAIN=crm.kodevon.com

# ─── WhatsApp Cloud API (Phase 4) ────────────────────────────
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_WABA_ID=
WA_WEBHOOK_VERIFY_TOKEN=

# ─── Meta (Instagram + Facebook — Phase 4) ───────────────────
META_APP_ID=
META_APP_SECRET=
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
META_IG_ACCOUNT_ID=

# ─── Gmail (Phase 4) ─────────────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_EMAIL=

# ─── Web Push / VAPID (Phase 8) ──────────────────────────────
# Generate with:
#   node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(JSON.stringify(k,null,2))"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@kodevon.com

# ─── Frontend (Next.js public) ───────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
