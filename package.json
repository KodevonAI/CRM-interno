{
  "name": "kodevon-crm",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.14.2",
  "scripts": {
    "dev:backend": "pnpm --filter backend dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:worker": "pnpm --filter worker dev",
    "build": "pnpm --filter backend build && pnpm --filter worker build && pnpm --filter frontend build",
    "db:generate": "pnpm --filter db generate",
    "db:migrate": "pnpm --filter db migrate:dev",
    "db:push": "pnpm --filter db push",
    "db:studio": "pnpm --filter db studio",
    "lint": "pnpm -r lint"
  }
}
